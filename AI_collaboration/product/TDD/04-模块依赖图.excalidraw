    {
      "type": "text",
      "id": "note_b",
      "x": 95,
      "y": 930,
      "width": 1320,
      "height": 58,
      "text": "实线表示主依赖；虚线表示回流或辅助依赖。大模块内部箭头已省略，仅保留跨边界和 Agent Flow 核心依赖。Context Engineering 管理 provider_config、默认模板、ShortTermMemory 与 StrategyPipeline，是 AgentBase._think、PlanAgent 和 plan step prompt 的统一上下文入口。",
      "fontSize": 17,
      "fontFamily": 5,
      "strokeColor": "#424242",
      "containerId": "note"
    }
